// ============================================================
//  FLOOVU — Plantilla de configuración
//
//  INSTRUCCIONES:
//  1. Copia este archivo y renómbralo a: config.js
//  2. Rellena ACCOUNT_EMAIL y API_SECRET con tus valores
//  3. NUNCA subas config.js al repositorio (ya está en .gitignore)
//  4. Este archivo de ejemplo SÍ puede subirse al repo
//
//  Los abogados NO se configuran aquí — se gestionan directamente
//  desde la sección Abogados del panel y se guardan en Google Sheets.
// ============================================================

window.FLOOVU_CONFIG = {

  // Email de la cuenta administradora
  ACCOUNT_EMAIL: 'admin@tudominio.com',

  // Token secreto — genera uno aleatorio largo (mínimo 32 caracteres)
  // Ejemplo: crypto.randomUUID() en la consola del navegador
  // Este mismo token debes configurarlo en el nodo "Validar Auth (Shared)" del workflow.
  API_SECRET: 'PON_AQUI_UN_TOKEN_SECRETO_LARGO_Y_ALEATORIO',

  // Endpoints de n8n (copia las URLs de tu instancia)
  WEBHOOKS: {
    ASSIGN:        'https://TU-INSTANCIA.easypanel.host/webhook/floovu-asignar-cliente',
    LAWYER_SAVE:   'https://TU-INSTANCIA.easypanel.host/webhook/floovu-guardar-abogado',
    LAWYER_DELETE: 'https://TU-INSTANCIA.easypanel.host/webhook/floovu-eliminar-abogado',
    FORCE_SYNC:    'https://TU-INSTANCIA.easypanel.host/webhook/floovu-force-sync',
    GET_DATA:      'https://TU-INSTANCIA.easypanel.host/webhook/floovu-get-data',
    HEALTH_CHECK:  'https://TU-INSTANCIA.easypanel.host/webhook/floovu-health-check',
  }

};
